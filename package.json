{
  "name": "spreadsheet-upload",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.16.3",
    "mbt": "^1.2.43",
    "rimraf": "^5.0.5",
    "yauzl": "^3.2.1",
    "yazl": "^3.3.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-bookshop": "cds watch --open demo.bookshop/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy spreadsheet-upload --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-publishing": "cds watch --open demo.publishing/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-manageauthors": "cds watch --open demo.manageauthors/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "fiori": {
      "bypass_draft": true
    },
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "destinations": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/bookshop",
    "app/publishing",
    "app/manageauthors"
  ]
}
