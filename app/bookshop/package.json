{
  "name": "bookshop",
  "version": "0.0.1",
  "description": "Bookshop",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "dependencies": {
    "ui5-cc-spreadsheetimporter": "1.7.4"
  },
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^0.4.0",
    "@sap/ui5-builder-webide-extension": "^1.1.9",
    "@sap/ux-ui5-tooling": "1",
    "@sapui5/types": "~1.136.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@ui5/cli": "^3.0.0",
    "typescript": "^5.1.6",
    "ui5-task-zipper": "^3.5.1",
    "ui5-tooling-transpile": "^3.3.7"
  },
  "scripts": {
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf",
    "build:cf": "npm run build:ui5 && npm run fix:uploader-comp",
    "build:ui5": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "fix:uploader-comp": "node ../../scripts/fix-spreadsheet-comp-id.js --quiet"
  }
}
