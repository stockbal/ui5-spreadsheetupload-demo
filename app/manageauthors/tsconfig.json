{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "moduleResolution": "node",
    "rootDir": "./webapp",
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "demo/manageauthors/*": ["./webapp/*"]
    },
    "types": ["@sapui5/types", "ui5-cc-spreadsheetimporter"]
  },
  "include": ["./webapp/**/*"]
}
